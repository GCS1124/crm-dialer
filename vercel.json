{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "client/dist",
  "routes": [
    {
      "src": "^/api$",
      "dest": "/api/router"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/router?route=$1"
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/:path((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
